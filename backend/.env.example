# Default OpenAI-compatible provider. DeepSeek uses this same client.
LIFETRACE_LLM_PROVIDER=openai
LIFETRACE_LLM_BASE_URL=https://api.deepseek.com
LIFETRACE_LLM_API_KEY=replace-with-your-deepseek-api-key
LIFETRACE_LLM_MODEL=deepseek-v4-flash

# Optional independent OpenAI-compatible embeddings provider for fuzzy search.
# If these two are omitted, embeddings reuse LIFETRACE_LLM_BASE_URL and LIFETRACE_LLM_API_KEY.
LIFETRACE_EMBEDDING_BASE_URL=https://api.openai.com/v1
LIFETRACE_EMBEDDING_API_KEY=replace-with-your-embedding-api-key
LIFETRACE_EMBEDDING_MODEL=replace-with-your-embedding-model-name
LIFETRACE_CHROMA_PATH=outputs/chroma_lifetrace
LIFETRACE_LLM_JSON_MODE=true
LIFETRACE_LLM_MAX_TOKENS=6000

# Use this block when calling vivo BlueLM cloud API for daily/month page generation.
# LIFETRACE_LLM_PROVIDER=vivo
LIFETRACE_VIVO_BASE_URL=https://api-ai.vivo.com.cn
LIFETRACE_VIVO_APP_ID=replace-with-your-vivo-app-id
LIFETRACE_VIVO_APP_KEY=replace-with-your-vivo-app-key
LIFETRACE_VIVO_MODEL=vivo-BlueLM-TB-Pro
LIFETRACE_VIVO_USE_MESSAGES=true
